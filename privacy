<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Privacy Policy — Pickr</title>
  <meta name="description" content="Pickr's privacy policy: how we collect, use, and protect your information." />
 
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
 
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
 
    :root {
      --cream: #f6f4ef;
      --cream-deep: #efebe2;
      --terracotta: #d97757;
      --terracotta-deep: #c25f3f;
      --ink: #1a1a18;
      --ink-soft: #555;
      --muted: #888;
      --border: #e8e4d6;
    }
 
    body {
      font-family: 'Inter', system-ui, sans-serif;
      background: var(--cream);
      color: var(--ink);
      line-height: 1.7;
      min-height: 100vh;
    }
 
    /* Top bar */
    .topbar {
      background: rgba(246, 244, 239, 0.92);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      border-bottom: 0.5px solid rgba(0,0,0,0.06);
      padding: 1rem 1.5rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
      position: sticky;
      top: 0;
      z-index: 50;
    }
    .topbar-logo {
      font-family: 'Instrument Serif', serif;
      font-size: 26px; letter-spacing: -0.5px;
      color: var(--ink); text-decoration: none;
      display: flex; align-items: baseline; gap: 4px;
    }
    .topbar-logo .dot { width: 6px; height: 6px; border-radius: 50%; background: var(--terracotta); }
    .back-link {
      font-size: 13px;
      color: var(--ink-soft);
      text-decoration: none;
      transition: color 0.2s;
    }
    .back-link:hover { color: var(--ink); }
 
    /* Container */
    .container {
      max-width: 760px;
      margin: 0 auto;
      padding: 3rem 1.5rem 5rem;
    }
 
    /* Hero */
    h1 {
      font-family: 'Instrument Serif', serif;
      font-size: clamp(40px, 6vw, 56px);
      font-weight: 400;
      line-height: 1.05;
      letter-spacing: -1.5px;
      margin-bottom: 0.75rem;
    }
    h1 em { font-style: italic; color: var(--terracotta); }
 
    .updated {
      color: var(--muted);
      font-size: 14px;
      margin-bottom: 3rem;
      padding-bottom: 1.5rem;
      border-bottom: 0.5px solid var(--border);
    }
 
    /* Headings */
    h2 {
      font-family: 'Instrument Serif', serif;
      font-size: 28px;
      font-weight: 400;
      letter-spacing: -0.5px;
      margin-top: 3rem;
      margin-bottom: 1rem;
      line-height: 1.2;
    }
    h2 .num {
      color: var(--terracotta);
      font-weight: 500;
      margin-right: 8px;
    }
    h3 {
      font-family: 'Inter', sans-serif;
      font-size: 16px;
      font-weight: 600;
      margin-top: 1.75rem;
      margin-bottom: 0.5rem;
      color: var(--ink);
    }
 
    /* Body text */
    p {
      color: var(--ink-soft);
      font-size: 15px;
      margin-bottom: 1rem;
    }
    p strong { color: var(--ink); }
 
    .summary-box {
      background: var(--cream-deep);
      border-left: 3px solid var(--terracotta);
      padding: 12px 16px;
      border-radius: 6px;
      margin-bottom: 1rem;
      font-size: 14px;
      color: var(--ink-soft);
    }
    .summary-box strong em {
      color: var(--terracotta-deep);
      font-style: italic;
      font-weight: 600;
    }
 
    ul {
      margin-bottom: 1rem;
      padding-left: 1.25rem;
    }
    ul li {
      color: var(--ink-soft);
      font-size: 15px;
      margin-bottom: 0.4rem;
      line-height: 1.65;
    }
 
    a {
      color: var(--terracotta-deep);
      text-decoration: underline;
      text-decoration-thickness: 1px;
      text-underline-offset: 2px;
    }
    a:hover { color: var(--terracotta); }
 
    /* TOC */
    .toc {
      background: #fff;
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 1.5rem;
      margin-bottom: 3rem;
    }
    .toc-title {
      font-family: 'Instrument Serif', serif;
      font-size: 20px;
      margin-bottom: 1rem;
      font-style: italic;
    }
    .toc-list {
      list-style: none;
      padding: 0;
      counter-reset: toc;
    }
    .toc-list li {
      counter-increment: toc;
      padding: 6px 0;
      font-size: 14px;
      border-bottom: 0.5px solid var(--border);
    }
    .toc-list li:last-child { border-bottom: none; }
    .toc-list li::before {
      content: counter(toc) ". ";
      color: var(--terracotta);
      font-weight: 500;
      margin-right: 4px;
    }
    .toc-list a {
      color: var(--ink-soft);
      text-decoration: none;
      transition: color 0.2s;
    }
    .toc-list a:hover { color: var(--terracotta-deep); }
 
    /* Footer */
    .footer {
      margin-top: 4rem;
      padding-top: 2rem;
      border-top: 0.5px solid var(--border);
      text-align: center;
      color: var(--muted);
      font-size: 13px;
    }
    .footer a {
      color: var(--ink-soft);
      text-decoration: none;
      margin: 0 12px;
    }
    .footer a:hover { color: var(--terracotta-deep); }
  </style>
</head>
